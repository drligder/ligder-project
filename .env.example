# Copy to `.env` in the project root (never commit `.env`).
#
# Database setup SQL lives in: for_developers/sql/ (run numbered scripts in order).

# --- Server API (used by `server/index.mjs` — keep secret) ---
# Get Project URL + service_role key from Supabase → Project Settings → API.
# The service role key MUST stay on the server only (bypasses RLS).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# Optional: secret for HMAC-signing admin session tokens (Bearer). If unset, a stable key is derived from the
# service role key. Set a long random string in production if you prefer rotation independent of Supabase.
# ADMIN_SESSION_SECRET=

# API-only mode (`npm run dev:server` or split dev): Express listens here. Default 8787.
# On Railway/Render/Fly, the platform sets PORT — that overrides SERVER_PORT.
SERVER_PORT=8787
# API-only bind address. Default 0.0.0.0 (required for cloud). Use 127.0.0.1 for localhost-only.
# LISTEN_HOST=0.0.0.0

# Combined dev (`npm run dev`): Vite + API share one port. Default 2000.
# PORT=2000

# Required on Netlify: Railway API origin (no trailing slash). `npm run build` runs scripts/netlify-prebuild.mjs
# which writes public/_redirects to proxy /api/* → Railway (browser uses same-origin /api; no CORS).
# Netlify: Environment variables → VITE_API_BASE → redeploy (Clear cache and deploy).
# VITE_API_BASE=https://your-api-host.example.com

# $LITE token SPL mint address (base58 from Solscan / explorer) — NOT a balance number
# Optional: if unset, LITE balance sync stores 0 until configured.
LITE_TOKEN_MINT=

# Solana JSON-RPC URL (used by the API for $LITE balance sync — Account settings).
# Put your own endpoint here (recommended): Shyft, Helius, QuickNode, Triton, etc.
# Shyft example shape: https://rpc.shyft.to?api_key=YOUR_API_KEY
# If unset, the server falls back to public mainnet (rate-limited).
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Optional: Solscan Pro for Liteboard creator (off by default — enable only if you want API parity with solscan.io).
# Set LITEBOARD_USE_SOLSCAN_CREATOR=1 and SOLSCAN_API_KEY. Header name is `token`. Debug: LITEBOARD_DEBUG_SOLSCAN=1
# LITEBOARD_USE_SOLSCAN_CREATOR=1
# SOLSCAN_API_KEY=

# Liteboard: by default any wallet that signs verify+create can open a board for any valid SPL mint (no creator proof).
# Set to enforce on-chain creator checks (Metaplex / Solscan opt-in / txs / etc.): LITEBOARD_STRICT_CREATOR_VERIFY=1
# LITEBOARD_STRICT_CREATOR_VERIFY=1
#
# pump.fun public API (https://frontend-api-v3.pump.fun/coins/{mint}). Self-serve Liteboard deploy always requires a pump.fun listing.
# Optional metadata/creator helpers: set 0 to skip outbound pump.fun for name/symbol (deploy listing check still uses pump.fun).
# LITEBOARD_USE_PUMP_FUN=0

# Optional: separate RPC for Memo relay txs (defaults to SOLANA_RPC_URL).
# SOLANA_MEMO_RPC_URL=https://api.mainnet-beta.solana.com

# Fee payer for server-relayed Solana Memo attestations (forum threads/replies).
# ONE of these formats (no quotes; no space after =):
#   1) JSON array from Solana keypair file id.json: [12,34,56,...]  (64 numbers)
#   2) Base58-encoded 64-byte secret key (single string)
# SOLANA_MEMO_FEE_PAYER_SECRET_KEY=

# Dividends: treasury signs SPL payouts (secret). Public address is implied; do not commit the secret.
# TREASURY_WALLET_SECRET_KEY=

# Optional: only this wallet may be the LITE sender when recording a pool deposit tx (public base58).
# Receiver is always the treasury wallet above. Legacy env name: DIVIDENDS_DEV_WALLET.
# SPL_DIVIDEND_SENDER=

# Supabase Storage: run for_developers/sql/003_storage_avatars.sql so profile photo uploads work.

# --- Optional: Vite client ---
# Only if the frontend calls Supabase directly later (public data). Not required for registration.
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-public-key
